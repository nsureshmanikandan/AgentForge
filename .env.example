# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_DEPLOYMENT_GPT45=gpt-4-5
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Database
DATABASE_URL=postgresql+asyncpg://architect:architect@localhost:5432/aiarchitect

# Auth
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Azure AI Search (RAG)
AZURE_SEARCH_ENDPOINT=https://YOUR_SEARCH.search.windows.net
AZURE_SEARCH_KEY=your_search_key
AZURE_SEARCH_INDEX=aiarchitect-index

# Observability — OpenTelemetry
# OTEL_EXPORTER options: jaeger | azure | gcp | aws | datadog | console | none
OTEL_EXPORTER=jaeger
OTEL_SERVICE_NAME=agentforge
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT_GRPC=http://localhost:4317

# Azure Monitor (set OTEL_EXPORTER=azure)
AZURE_MONITOR_CONNECTION_STRING=InstrumentationKey=your-key;...

# Google Cloud Trace (set OTEL_EXPORTER=gcp)
GCP_PROJECT_ID=your-gcp-project-id

# AWS X-Ray via ADOT (set OTEL_EXPORTER=aws, point endpoint at ADOT collector)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Datadog (set OTEL_EXPORTER=datadog, point endpoint at DD agent OTLP port)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
